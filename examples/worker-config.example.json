{
  "app_token": "<local-feishu-base-app-token>",
  "feishu_cli": "lark-cli",
  "feishu_cli_flavor": "lark",
  "worker_version": "dev",
  "required_hermes_secrets": [
    "FEISHU_ACCESS_TOKEN"
  ],
  "tables": {
    "brands": {
      "table_id": "<local-brands-table-id>",
      "fields": {
        "brand_id": "<field-brand-id>",
        "brand_name": "<field-brand-name>",
        "tone": "<field-tone>"
      }
    },
    "pins": {
      "table_id": "<local-pins-table-id>",
      "fields": {
        "status": "<field-status>",
        "scheduled_at": "<field-scheduled-at>",
        "publisher_run_id": "<field-publisher-run-id>",
        "claim_expires_at": "<field-claim-expires-at>",
        "last_attempt_at": "<field-last-attempt-at>",
        "publish_attempts": "<field-publish-attempts>",
        "prepare_run_id": "<field-prepare-run-id>",
        "prepare_expires_at": "<field-prepare-expires-at>",
        "last_error": "<field-last-error>",
        "product_name": "<field-product-name>",
        "product_link": "<field-product-link>",
        "pinterest_board": "<field-pinterest-board>",
        "source_image": "<field-source-image>",
        "processed_image": "<field-processed-image>",
        "draft_title": "<field-draft-title>",
        "draft_description": "<field-draft-description>",
        "draft_tags": "<field-draft-tags>",
        "draft_alt_text": "<field-draft-alt-text>",
        "final_title": "<field-final-title>",
        "final_description": "<field-final-description>",
        "final_tags": "<field-final-tags>",
        "final_alt_text": "<field-final-alt-text>",
        "final_board": "<field-final-board>",
        "final_image": "<field-final-image>",
        "pin_url": "<field-pin-url>",
        "published_at": "<field-published-at>"
      }
    },
    "runs": {
      "table_id": "<local-runs-table-id>",
      "fields": {
        "run_id": "<field-run-id>",
        "pin": "<field-pin>",
        "action": "<field-action>",
        "ok": "<field-ok>",
        "input_snapshot": "<field-input-snapshot>",
        "output_snapshot": "<field-output-snapshot>",
        "error": "<field-error>",
        "worker_version": "<field-worker-version>",
        "hermes_run_id": "<field-hermes-run-id>",
        "hermes_agent_id": "<field-hermes-agent-id>",
        "hermes_job_id": "<field-hermes-job-id>"
      }
    },
    "runtime_locks": {
      "table_id": "<local-runtime-locks-table-id>",
      "fields": {
        "lock_name": "<field-lock-name>",
        "owner_run_id": "<field-owner-run-id>",
        "owner_hermes_run_id": "<field-owner-hermes-run-id>",
        "lock_expires_at": "<field-lock-expires-at>",
        "locked_at": "<field-locked-at>",
        "last_error": "<field-lock-last-error>"
      }
    }
  }
}
