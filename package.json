{
  "name": "pinterest-autopin",
  "version": "1.1.0",
  "description": "Single-pin Pinterest publishing with CLI and Hermes Skill interfaces",
  "main": "publish_playwright.js",
  "bin": {
    "pinterest-autopin": "./tools/pinterest_publish_pin.py"
  },
  "scripts": {
    "check": "node --check publish_playwright.js && python3 -m py_compile tools/pinterest_publish_pin.py",
    "pin:validate": "python3 tools/pinterest_publish_pin.py --mode validate",
    "pin:test": "python3 tools/pinterest_publish_pin.py --mode test",
    "pin:publish": "python3 tools/pinterest_publish_pin.py --mode final"
  },
  "keywords": [
    "pinterest",
    "agent-tool",
    "automation",
    "playwright",
    "chrome-cdp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.58.2",
    "sharp": "^0.34.5"
  }
}
