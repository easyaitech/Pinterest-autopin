{
  "name": "pinterest-autopin",
  "version": "1.3.1",
  "description": "Single-pin Pinterest publishing with CLI and Hermes Skill interfaces",
  "main": "publish_playwright.js",
  "bin": {
    "pinterest-autopin": "./tools/pinterest_publish_pin.py"
  },
  "scripts": {
    "check": "node --check publish_playwright.js && python3 -m compileall -q pinterest_autopin tools && npm test",
    "test": "python3 -m unittest discover -s tests",
    "pin:validate": "python3 tools/pinterest_publish_pin.py --mode validate",
    "pin:test": "python3 tools/pinterest_publish_pin.py --mode test",
    "pin:publish": "python3 tools/pinterest_publish_pin.py --mode final",
    "pin:check-login": "python3 tools/pinterest_publish_pin.py --mode check-login",
    "pin:profile": "python3 tools/pinterest_publish_pin.py --print-chrome-profile",
    "pin:init-profile": "python3 tools/pinterest_publish_pin.py --init-chrome-profile",
    "worker:onboard": "python3 tools/feishu_pinterest_worker.py onboard",
    "worker:doctor": "python3 tools/feishu_pinterest_worker.py doctor",
    "worker:prepare": "python3 tools/feishu_pinterest_worker.py prepare",
    "worker:publish": "python3 tools/feishu_pinterest_worker.py publish"
  },
  "keywords": [
    "pinterest",
    "agent-tool",
    "automation",
    "playwright",
    "chrome-profile"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.58.2",
    "sharp": "^0.34.5"
  }
}
